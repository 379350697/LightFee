[Unit]
Description=LightFee unattended funding arbitrage engine
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=/opt/lightfee
EnvironmentFile=/etc/lightfee/lightfee.env
ExecStart=/opt/lightfee/target/release/lightfee /etc/lightfee/live.toml
Restart=on-failure
RestartSec=3
TimeoutStopSec=15
KillSignal=SIGINT
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
